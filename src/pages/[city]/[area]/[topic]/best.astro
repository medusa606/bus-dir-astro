---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import LandingHero from '../../../../components/landing/LandingHero.astro';
import EditorialSection from '../../../../components/landing/EditorialSection.astro';
import LandingGrid from '../../../../components/landing/LandingGrid.astro';
import LandingSchema from '../../../../components/landing/LandingSchema.astro';
import { supabase } from '../../../../lib/supabase.js';
import { slugToTitle } from '../../../../utils/helpers.js';
import { TOPIC_TAXONOMY, filterListingsByTopic } from '../../../../utils/topicTaxonomy.js';
import { buildTemplateContent, buildSeoTitle } from '../../../../utils/landingCopy.js';

const citySlug = Astro.params.city!;
const areaSlug = Astro.params.area!;
const topicSlug = Astro.params.topic!;

// Fetch first listings page and landing row in parallel to avoid serial round trips
const PAGE_SIZE = 1000;
const [{ data: firstPage }, { data: landingRow }] = await Promise.all([
    supabase
        .from('listings')
        .select('*')
        .eq('city_slug', citySlug)
        .eq('area_slug', areaSlug)
        .or('status.not.in.(closed,unverified),status.is.null')
        .range(0, PAGE_SIZE - 1),
    supabase
        .from('landing_pages')
        .select('*')
        .eq('city', citySlug)
        .eq('area', areaSlug)
        .eq('topic', topicSlug)
        .eq('status', 'published')
        .maybeSingle(),
]);

let allListings: any[] = firstPage || [];
// Continue pagination only if the area has >1000 listings
if (allListings.length === PAGE_SIZE) {
    let from = PAGE_SIZE;
    while (true) {
        const { data } = await supabase
            .from('listings')
            .select('*')
            .eq('city_slug', citySlug)
            .eq('area_slug', areaSlug)
            .or('status.not.in.(closed,unverified),status.is.null')
            .range(from, from + PAGE_SIZE - 1);
        if (!data || data.length === 0) break;
        allListings = allListings.concat(data);
        if (data.length < PAGE_SIZE) break;
        from += PAGE_SIZE;
    }
}

// For custom curator topics not in TOPIC_TAXONOMY, use all area listings
const listings = TOPIC_TAXONOMY[topicSlug as keyof typeof TOPIC_TAXONOMY]
    ? (filterListingsByTopic(allListings, topicSlug) || [])
    : allListings;

if (listings.length === 0 && !landingRow) {
    return Astro.redirect('/404');
}

const TIER_ORDER: Record<string, number> = { editors_choice: 0, recommended: 1, google_ranked: 2, standard: 3 };
const sortedListings = [...listings].sort(
    (a, b) => (TIER_ORDER[a.ranking_tier] ?? 3) - (TIER_ORDER[b.ranking_tier] ?? 3)
);

const topPicks = sortedListings.filter(
    l => l.ranking_tier === 'editors_choice' || l.ranking_tier === 'recommended'
).slice(0, 6);

// Map all listings by ID for per-section lookup
const listingById = new Map<string, any>(allListings.map(l => [l.id, l]));

// Content: use Supabase row if available, otherwise build from template
const content = landingRow
    ? {
        title:       landingRow.title,
        seoTitle:    landingRow.seo_title,
        description: landingRow.description,
        intro:       landingRow.intro,
        sections:    landingRow.sections || [],
        featuredIds: landingRow.featured_ids || [],
      }
    : buildTemplateContent(citySlug, areaSlug, topicSlug, listings);

const topic = TOPIC_TAXONOMY[topicSlug as keyof typeof TOPIC_TAXONOMY];
const topicLabel = topic?.label || slugToTitle(topicSlug);
const cityTitle = slugToTitle(citySlug);
const areaTitle = slugToTitle(areaSlug);

const seoTitle = content.seoTitle || buildSeoTitle(citySlug, areaSlug, topicSlug);
const pageDescription = content.description;

const heroListing = sortedListings.find(l => l.image_url && l.ranking_tier === 'editors_choice')
    || sortedListings.find(l => l.image_url);
const heroImageUrl = landingRow?.hero_image_url || heroListing?.image_url || null;

const crumbs = [
    { label: cityTitle, href: `/${citySlug}` },
    { label: areaTitle, href: `/${citySlug}/${areaSlug}` },
    { label: `Best ${topicLabel} in ${areaTitle}` },
];

const breadcrumbData = [
    { name: 'Home', url: '/' },
    { name: cityTitle, url: `/${citySlug}` },
    { name: areaTitle, url: `/${citySlug}/${areaSlug}` },
    { name: content.title, url: `/${citySlug}/${areaSlug}/${topicSlug}/best` },
];

// Section picks: pinned via featuredIds or top picks by tier
const sectionPicks = content.featuredIds?.length
    ? content.featuredIds
        .map((id: string) => listings.find((l: any) => l.id === id))
        .filter((l: any) => l != null)
    : topPicks;

const editorialSections: any[] = (content.sections || []).map((section: any, i: number) => ({
    ...section,
    listing: (section.section_listing_id ? listingById.get(section.section_listing_id) : null) || sectionPicks[i] || null,
    floatDirection: i % 2 === 0 ? 'right' : 'left',
}));

// Build grid: exclude editorial picks; for booking-field topics prioritise booking matches in related categories, then fill with tier-ranked same-category listings
const sectionPickIds = new Set<string>(sectionPicks.map((l: any) => l.id));
let gridListings: any[];
if ((topic as any)?.queryType === 'booking_field' && (topic as any)?.relatedCategories) {
    const relatedCats: string[] = (topic as any).relatedCategories;
    const bookingField: string = (topic as any).queryValues[0];
    const primaryPool = [...allListings]
        .filter((l: any) =>
            !sectionPickIds.has(l.id) &&
            relatedCats.includes(l.category_slug) &&
            l[bookingField] && String(l[bookingField]).trim() !== ''
        )
        .sort((a: any, b: any) => (TIER_ORDER[a.ranking_tier] ?? 3) - (TIER_ORDER[b.ranking_tier] ?? 3));
    const primaryIds = new Set<string>(primaryPool.map((l: any) => l.id));
    const secondaryPool = [...allListings]
        .filter((l: any) =>
            !sectionPickIds.has(l.id) &&
            !primaryIds.has(l.id) &&
            relatedCats.includes(l.category_slug)
        )
        .sort((a: any, b: any) => (TIER_ORDER[a.ranking_tier] ?? 3) - (TIER_ORDER[b.ranking_tier] ?? 3));
    gridListings = [...primaryPool, ...secondaryPool].slice(0, 12);
} else {
    gridListings = sortedListings
        .filter((l: any) => !sectionPickIds.has(l.id))
        .slice(0, 12);
}

const parentUrl = `/${citySlug}/${areaSlug}`;
const parentLabel = `Browse everything in ${areaTitle}`;
const cityTopicUrl = `/${citySlug}/${topicSlug}/best`;
const cityTopicLabel = `Best ${topicLabel} in all of ${cityTitle} →`;
---

<BaseLayout title={seoTitle} description={pageDescription} ogImage={heroImageUrl}>
    <LandingSchema
        listings={sortedListings.slice(0, 10)}
        pageTitle={content.title}
        pageUrl={`/${citySlug}/${areaSlug}/${topicSlug}/best`}
        breadcrumbs={breadcrumbData}
    />

    <LandingHero
        title={content.title}
        intro={content.intro}
        topicLabel={topicLabel}
        city={citySlug}
        area={areaSlug}
        count={listings.length}
        topImageUrl={heroImageUrl}
        emoji={topic?.emoji}
        pluralLabel={topic?.pluralLabel}
    />

    <div class="landing-page">
        <div class="landing-page__breadcrumbs">
            <Breadcrumbs crumbs={crumbs} />
        </div>

        <div class="landing-page__body">
            {editorialSections.map((section: any) => (
                <EditorialSection
                    heading={section.heading}
                    body={section.body}
                    listing={section.listing}
                    floatDirection={section.floatDirection}
                    sectionImageUrl={section.image_url ?? undefined}
                />
            ))}
        </div>

        {gridListings.length > 0 && (
            <LandingGrid
                listings={gridListings}
                heading={`All our picks — ${content.title}`}
            />
        )}

        <div class="landing-page__footer-links">
            <a href={parentUrl} class="landing-page__browse-link">
                {parentLabel} →
            </a>
            <a href={cityTopicUrl} class="landing-page__browse-link landing-page__browse-link--secondary">
                {cityTopicLabel}
            </a>
        </div>
    </div>
</BaseLayout>

<style>
.landing-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg);
}

.landing-page__breadcrumbs {
    margin-bottom: var(--space-xl);
}

.landing-page__body {
    margin-bottom: var(--space-2xl);
}

.landing-page__footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border, #e5e7eb);
}

.landing-page__browse-link {
    font-size: 0.95rem;
    color: var(--color-accent, #7c3aed);
    text-decoration: none;
    font-weight: 500;
}

.landing-page__browse-link--secondary {
    color: var(--color-text-muted, #6b7280);
}

.landing-page__browse-link:hover {
    text-decoration: underline;
}
</style>
