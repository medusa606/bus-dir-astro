---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TieredListings from '../../components/TieredListings.astro';
import { supabase } from '../../lib/supabase.js';
import { slugToTitle, getEmoji } from '../../utils/helpers.js';

export async function getStaticPaths() {
    const { data } = await supabase
        .from('listings')
        .select('city_slug')
        .eq('status', 'Published');
    const cities = [...new Set(data?.map(l => l.city_slug).filter(Boolean))];
    return cities.map(city => ({ params: { city } }));
}

const { city } = Astro.params;
const cityTitle = slugToTitle(city);

const { data: listings } = await supabase
    .from('listings')
    .select('*')
    .eq('status', 'Published')
    .eq('city_slug', city);

const areaCounts = {};
listings?.forEach(l => { if (l.area_slug) areaCounts[l.area_slug] = (areaCounts[l.area_slug] || 0) + 1; });

const categoryCounts = {};
listings?.forEach(l => { if (l.category_slug) categoryCounts[l.category_slug] = (categoryCounts[l.category_slug] || 0) + 1; });

const sortedAreas = Object.entries(areaCounts).sort((a, b) => a[0].localeCompare(b[0]));
const sortedCategories = Object.entries(categoryCounts).sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title={`People in ${cityTitle}`} description={`Discover independent makers, traders, and service providers in ${cityTitle}.`}>

<section style="padding: var(--space-3xl) 0 var(--space-xl); background: linear-gradient(135deg, var(--parchment) 0%, var(--blush-light) 100%);">
    <div class="container">
        <Breadcrumbs crumbs={[{ label: cityTitle }]} />
        <h1 style="margin-top: var(--space-lg);">People in {cityTitle}</h1>
        <div class="divider"></div>
        <p class="text-secondary" style="font-size: 1.05rem; max-width: 550px;">
            {listings?.length || 0} people across {Object.keys(areaCounts).length} areas
            — every one of them here because they deserve to be.
        </p>
    </div>
</section>

<!-- Areas -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <h2>Browse by area</h2>
            <div class="divider"></div>
            <p>Select a neighbourhood to see what's nearby.</p>
        </div>
        <div class="areas-grid">
            {sortedAreas.map(([area, count]) => (
                <a href={`/${city}/${area}`} class="area-card">
                    <div>
                        <h3 style="text-transform: capitalize;">{area.replace(/-/g, ' ')}</h3>
                        <p>{count} {count === 1 ? 'person' : 'people'}</p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<!-- Categories -->
<section class="section" style="background: var(--white);">
    <div class="container">
        <div class="section-header">
            <h2>Browse by category</h2>
            <div class="divider"></div>
            <p>Find the right person for what you need.</p>
        </div>
        <div class="category-grid">
            {sortedCategories.map(([cat, count]) => (
                <a href={`/${city}/${cat}`} class="category-card">
                    <div class="category-card__icon">{getEmoji(cat)}</div>
                    <div class="category-card__text">
                        <h4>{slugToTitle(cat)}</h4>
                        <p>{count} {count === 1 ? 'person' : 'people'}</p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<!-- All Listings Tiered -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <h2>Everyone in {cityTitle}</h2>
            <div class="divider"></div>
        </div>
        <TieredListings listings={listings} />
    </div>
</section>

<!-- CTA -->
<section class="section">
    <div class="container">
        <div class="cta-banner">
            <h2>Doing great work in {cityTitle}?</h2>
            <p>Meridian is for independent people who care about their craft. If that's you, we'd love to include you.</p>
            <a href="#" class="btn btn--accent">Apply to be listed</a>
        </div>
    </div>
</section>

</BaseLayout>
