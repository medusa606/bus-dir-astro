---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SubCategoryFilter from '../../components/SubCategoryFilter.astro';
import TieredListings from '../../components/TieredListings.astro';
import StarRating from '../../components/StarRating.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import SocialFeed from '../../components/SocialFeed.astro';
import Map from '../../components/Map.astro';
import { supabase, getAreaHeroUrl } from '../../lib/supabase.js';
import { slugToTitle, getEmoji, RANKING_TIERS, normaliseCategory } from '../../utils/helpers.js';
import { getCategoryFallbackImage, getTagBasedImage, getImageByCategory } from '../../utils/categoryImages.js';
import { getSubCategories, filterBySubCategory } from '../../utils/subCategoryHelpers.js';

export async function getStaticPaths() {
    // Paginate to fetch all listings past Supabase's 1000-row default limit
    const PAGE_SIZE = 1000;
    let allListings: any[] = [];
    let from = 0;
    while (true) {
        const { data } = await supabase
            .from('listings')
            .select('*')
            .or('status.not.in.(closed,unverified),status.is.null')
            .range(from, from + PAGE_SIZE - 1);
        if (!data || data.length === 0) break;
        allListings = allListings.concat(data);
        if (data.length < PAGE_SIZE) break;
        from += PAGE_SIZE;
    }
    const listings = allListings;

    if (!listings) return [];

    const allCategories = new Set(listings.map(l => String(l.category_slug)).filter(Boolean));
    const paths = [];
    const seen = new Set();

    listings.forEach(l => {
        const citySlug = String(l.city_slug).toLowerCase().trim();

        if (l.category_slug) {
            const categorySlug = String(l.category_slug).toLowerCase().trim();
            const key = `cat:${citySlug}/${categorySlug}`;
            if (!seen.has(key)) {
                seen.add(key);
                paths.push({
                    params: { city: citySlug, slug: categorySlug },
                    props: { type: 'city-category', citySlug: l.city_slug, categorySlug: categorySlug, allCategories: [...allCategories] }
                });
            }
        }
        if (l.area_slug && !allCategories.has(String(l.area_slug))) {
            const areaSlug = String(l.area_slug).toLowerCase().trim();
            const key = `area:${citySlug}/${areaSlug}`;
            if (!seen.has(key)) {
                seen.add(key);
                paths.push({
                    params: { city: citySlug, slug: areaSlug },
                    props: { type: 'area', citySlug: l.city_slug, areaSlug: areaSlug, allCategories: [...allCategories] }
                });
            }
        }
        if (l.area_slug && l.category_slug) {
            const areaSlug = String(l.area_slug).toLowerCase().trim();
            const categorySlug = String(l.category_slug).toLowerCase().trim();
            const key = `areacat:${citySlug}/${areaSlug}/${categorySlug}`;
            if (!seen.has(key)) {
                seen.add(key);
                paths.push({
                    params: { city: citySlug, slug: `${areaSlug}/${categorySlug}` },
                    props: { type: 'area-category', citySlug: l.city_slug, areaSlug: areaSlug, categorySlug: categorySlug, allCategories: [...allCategories] }
                });
            }
        }
        if (l.area_slug && l.business_slug) {
            const areaSlug = String(l.area_slug).toLowerCase().trim();
            const businessSlug = String(l.business_slug).toLowerCase().trim();
            paths.push({
                params: { city: citySlug, slug: `${areaSlug}/${businessSlug}` },
                props: { type: 'listing', citySlug: l.city_slug, areaSlug: areaSlug, businessSlug: businessSlug, listing: l, allCategories: [...allCategories] }
            });
        }
    });
    return paths;
}

const { type, citySlug, areaSlug, categorySlug, businessSlug, listing: directListing } = Astro.props;

let pageTitle = '';
let pageDescription = '';
let listings = [];
let listing = directListing || null;
let crumbs = [];
let areaHeroUrl: string | null = null;

// Get sub-category filter from URL parameters
const subCategorySlug = Astro.url.searchParams.get('subCategory');

const cityTitle = slugToTitle(citySlug);
const areaTitle = slugToTitle(areaSlug);
const catTitle = slugToTitle(categorySlug);

if (type === 'city-category') {
    pageTitle = `${catTitle} in ${cityTitle}`;
    pageDescription = `Find the best ${catTitle.toLowerCase()} in ${cityTitle}.`;
    crumbs = [{ label: cityTitle, href: `/${citySlug}` }, { label: catTitle }];
    const { data } = await supabase.from('listings').select('*').or('status.not.in.(closed,unverified),status.is.null').eq('city_slug', citySlug).eq('category_slug', categorySlug).not('address', 'is', null);
    listings = data || [];
    // Apply sub-category filter if provided
    if (subCategorySlug) {
        listings = filterBySubCategory(listings, subCategorySlug);
    }

} else if (type === 'area') {
    pageTitle = `People in ${areaTitle}, ${cityTitle}`;
    pageDescription = `Discover independent makers and traders in ${areaTitle}, ${cityTitle}.`;
    crumbs = [{ label: cityTitle, href: `/${citySlug}` }, { label: areaTitle }];
    const { data } = await supabase.from('listings').select('*').or('status.not.in.(closed,unverified),status.is.null').eq('city_slug', citySlug).eq('area_slug', areaSlug).not('address', 'is', null);
    listings = data || [];
    // Apply sub-category filter if provided
    if (subCategorySlug) {
        listings = filterBySubCategory(listings, subCategorySlug);
    }
    const { data: areaData } = await supabase
        .from('areas')
        .select('use_hero_image, hero_image_url')
        .eq('city_slug', citySlug)
        .eq('area_slug', areaSlug)
        .maybeSingle();
    if (areaData?.use_hero_image && areaData?.hero_image_url) {
        areaHeroUrl = areaData.hero_image_url;
    }

} else if (type === 'area-category') {
    pageTitle = `${catTitle} in ${areaTitle}, ${cityTitle}`;
    pageDescription = `Find ${catTitle.toLowerCase()} in ${areaTitle}, ${cityTitle}.`;
    crumbs = [{ label: cityTitle, href: `/${citySlug}` }, { label: areaTitle, href: `/${citySlug}/${areaSlug}` }, { label: catTitle }];
    const { data } = await supabase.from('listings').select('*').or('status.not.in.(closed,unverified),status.is.null').eq('city_slug', citySlug).eq('area_slug', areaSlug).eq('category_slug', categorySlug).not('address', 'is', null);
    listings = data || [];
    // Apply sub-category filter if provided
    if (subCategorySlug) {
        listings = filterBySubCategory(listings, subCategorySlug);
    }

} else if (type === 'listing' && listing) {
    pageTitle = listing.name;
    pageDescription = listing.description || `Find ${listing.name} in ${areaTitle}, ${cityTitle}.`;
    crumbs = [
        { label: cityTitle, href: `/${citySlug}` },
        { label: areaTitle, href: `/${citySlug}/${areaSlug}` },
        { label: listing.name }
    ];
}

const tier = listing ? (RANKING_TIERS[listing.ranking_tier] || RANKING_TIERS.standard) : null;

// Local overrides — keyed by business_slug
// Used until columns are added to Supabase
const LOCAL_ILLUSTRATIONS = {
    'no12-easton-cafe': '/illustrations/bristol-easton-no12cafe.webp',
};
const LOCAL_FOUNDERS_IMAGES = {
    'no12-easton-cafe': '/founders/bristol-easton-no12cafe.webp',
};
const LOCAL_LOGOS = {
    'no12-easton-cafe': '/logo/bristol-easton-no12cafe.webp',
};

const illustrationUrl = listing
    ? (listing.illustration_url || LOCAL_ILLUSTRATIONS[listing.business_slug] || null)
    : null;
const imageCategoryImage = listing
    ? (listing.image_category && getImageByCategory(listing.image_category, listing.business_slug))
    : null;
const heroImage = listing
    ? (illustrationUrl || listing.image_key || imageCategoryImage || getTagBasedImage(listing.tags, listing.category_slug, listing.business_slug) || listing.image_url || getCategoryFallbackImage(listing.category_slug, listing.business_slug) || '/placeholders/default.svg')
    : null;
const foundersImage = listing
    ? (listing.founders_image || LOCAL_FOUNDERS_IMAGES[listing.business_slug] || null)
    : null;
const foundersStory = listing?.founders_story || null;
const logoUrl = listing
    ? (listing.show_logo && listing.logo_url ? listing.logo_url : LOCAL_LOGOS[listing.business_slug] || null)
    : null;

const jsonLd = (type === 'listing' && listing) ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": listing.name,
    "description": listing.description,
    "address": {
        "@type": "PostalAddress",
        "addressLocality": cityTitle,
        "addressRegion": areaTitle,
        "addressCountry": "GB"
    },
    ...(listing.google_rating && {
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": listing.google_rating,
            "reviewCount": listing.google_review_count || 0
        }
    }),
    "image": illustrationUrl || listing.image_url,
    "telephone": listing.phone,
    "url": listing.website
}) : null;
---

<BaseLayout title={pageTitle} description={pageDescription}>

{jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

{type === 'listing' && listing ? (
    <!-- ════════ INDIVIDUAL LISTING PAGE ════════ -->
    <div class={`listing-hero${illustrationUrl ? ' listing-hero--illustration' : ''}`}>
        <img
            src={heroImage}
            alt={listing.name}
            class="listing-hero__cover"
        />
        {!illustrationUrl && <div class="listing-hero__overlay"></div>}
    </div>

    <div class="listing-header">
        <div class="listing-header__inner">
            <div class="listing-header__info">
                <div class="tags" style="margin-bottom: var(--space-sm);">
                    <a href={`/${listing.city_slug}/${listing.category_slug}`} class="tag tag--category tag--link">{listing.category || 'Local Business'}</a>
                    {tier && tier.label && (
                        <a href={`/${listing.city_slug}#${tier.anchorSlug}`} class={`tag tag--tier-${listing.ranking_tier === 'editors_choice' ? 'editors' : listing.ranking_tier === 'recommended' ? 'recommended' : 'google'} tag--link`}>
                            {tier.icon} {tier.label}
                        </a>
                    )}
                    <a href={`/${listing.city_slug}/${listing.area_slug}`} class="tag tag--location tag--link" style="text-transform: capitalize;">
                        📍 {listing.area_slug?.replace(/-/g, ' ')}, {cityTitle}
                    </a>
                </div>
                <h1>{listing.name}</h1>
                <p class="subtitle">{listing.description?.substring(0, 100) || 'Independent local business'}...</p>
            </div>
            {logoUrl ? (
                <div class="listing-header__logo">
                    {listing.website ? (
                        <a href={listing.website} target="_blank" rel="noopener noreferrer">
                            <img src={logoUrl} alt={`${listing.name} logo`} />
                        </a>
                    ) : (
                        <img src={logoUrl} alt={`${listing.name} logo`} />
                    )}
                </div>
            ) : (
                <div class="listing-header__actions">
                    {listing.phone && <a href={`tel:${listing.phone}`} class="btn btn--primary btn--sm">📞 Call</a>}
                    {listing.website && <a href={listing.website} target="_blank" rel="noopener" class="btn btn--outline btn--sm">↗ Website</a>}
                </div>
            )}
        </div>
    </div>

    <!-- Contact Info Box -->
    {(listing.address || listing.phone || listing.email || listing.website) && (
        <div class="contact-info-box">
            <div class="contact-info-container">
                {listing.address && (
                    <div class="contact-item">
                        <span class="contact-icon">📍</span>
                        <div>
                            <p class="contact-label">Address</p>
                            <a
                                href={listing.google_maps_url || `https://www.google.com/maps/?q=${encodeURIComponent(`${listing.name}, ${listing.address}`)}`}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="contact-value contact-link"
                            >{listing.address}</a>
                        </div>
                    </div>
                )}
                {listing.phone && (
                    <div class="contact-item">
                        <span class="contact-icon">📞</span>
                        <div>
                            <p class="contact-label">Phone</p>
                            <a href={`tel:${listing.phone}`} class="contact-value contact-link">{listing.phone}</a>
                        </div>
                    </div>
                )}
                {listing.email && (
                    <div class="contact-item">
                        <span class="contact-icon">✉️</span>
                        <div>
                            <p class="contact-label">Email</p>
                            <a href={`mailto:${listing.email}`} class="contact-value contact-link">{listing.email}</a>
                        </div>
                    </div>
                )}
                {listing.website && (
                    <div class="contact-item">
                        <span class="contact-icon">🌐</span>
                        <div>
                            <p class="contact-label">Website</p>
                            <a href={listing.website} target="_blank" rel="noopener noreferrer" class="contact-value contact-link">Visit Website ↗</a>
                        </div>
                    </div>
                )}
            </div>
        </div>
    )}

    <div class="listing-body">
        <div class="listing-main">

            <!-- About -->
            {listing.description && (
            <div class="listing-section listing-section--about">
                <h2>About {listing.name}</h2>
                <p>{listing.description}</p>
            </div>
            )}

            <!-- Services Section -->
            {listing.services_offered && listing.services_offered.length > 0 && (
                <section class="listing-section">
                    <h2>What They Offer</h2>
                    <div class="services-list">
                        {listing.services_offered.map(service => (
                            <div class="service-item">{service}</div>
                        ))}
                    </div>
                </section>
            )}

            <!-- Photos Section -->
            {listing.photo_gallery && listing.photo_gallery.length > 0 && (
                <section class="listing-section">
                    <h2>Photos</h2>
                    <div class="gallery-grid">
                        {listing.photo_gallery.map(photo => (
                            <img src={photo} alt={listing.name} />
                        ))}
                    </div>
                </section>
            )}

            <!-- Founder's Story -->
            {(foundersImage || foundersStory) && (
                <div class="listing-section">
                    <h2>The story behind {listing.name}</h2>
                    <div class="founders-card">
                        {foundersImage && (
                            <div class="founders-card__image-wrap">
                                <img src={foundersImage} alt={`Founder of ${listing.name}`} class="founders-card__image" />
                            </div>
                        )}
                        {foundersStory && (
                            <div class="founders-card__story">
                                <blockquote class="founders-quote">
                                    <p>{foundersStory}</p>
                                </blockquote>
                            </div>
                        )}
                    </div>
                </div>
            )}

            <!-- Reviews -->
            {listing.google_rating && (
                <div class="listing-section">
                    <h2>What people think</h2>
                    <div class="trust-card">
                        <h4>Ratings</h4>
                        <div class="rating-row">
                            {listing.google_maps_url ? (
                                <a href={listing.google_maps_url} target="_blank" rel="noopener noreferrer" class="rating-source rating-link">Google Reviews ↗</a>
                            ) : (
                                <span class="rating-source">Google Reviews</span>
                            )}
                            {listing.google_maps_url ? (
                                <a href={listing.google_maps_url} target="_blank" rel="noopener noreferrer" class="rating-value rating-link">
                                    <span class="stars">{'★'.repeat(Math.floor(listing.google_rating))}{'☆'.repeat(5 - Math.floor(listing.google_rating))}</span>
                                    {listing.google_rating} ({listing.google_review_count || 0} reviews)
                                </a>
                            ) : (
                                <span class="rating-value">
                                    <span class="stars">{'★'.repeat(Math.floor(listing.google_rating))}{'☆'.repeat(5 - Math.floor(listing.google_rating))}</span>
                                    {listing.google_rating} ({listing.google_review_count || 0} reviews)
                                </span>
                            )}
                        </div>
                    </div>
                </div>
            )}
        </div>

        <!-- Sidebar -->
        <div class="listing-sidebar">

            <!-- Breadcrumbs in sidebar -->
            <div class="sidebar-widget">
                <h3>Location</h3>
                <Breadcrumbs crumbs={crumbs} />
            </div>

            <!-- Social Links -->
            <div class="sidebar-widget">
                <h3>Find online</h3>
                <SocialLinks listing={listing} />
                <SocialFeed feed={listing.social_feed} maxItems={3} />
            </div>

            <!-- Map Widget -->
            {listing.address && listing.latitude && listing.longitude && (
                <div class="sidebar-widget sidebar-widget--map">
                    <h3>Location</h3>
                    <Map address={listing.address} latitude={listing.latitude} longitude={listing.longitude} />
                    <a 
                        href={`https://www.google.com/maps/?q=${encodeURIComponent(`${listing.name}, ${listing.address}`)}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn btn--outline btn--block"
                        style="margin-top: var(--space-md); display: block; text-align: center;"
                    >
                        Find Us on Google Maps
                    </a>
                </div>
            )}

            <!-- Hours Widget -->
            {listing.opening_hours && (
                <div class="sidebar-widget">
                    <h3>Hours</h3>
                    <ul class="hours-list">
                        {(() => {
                            let hoursData = listing.opening_hours;
                            
                            // Handle if it's a string
                            if (typeof hoursData === 'string') {
                                // Try parsing as JSON first
                                try {
                                    hoursData = JSON.parse(hoursData);
                                } catch (e) {
                                    // Try parsing as pipe-separated format
                                    // e.g. "Monday: Closed | Tuesday: 4:00 – 9:00 PM | ..."
                                    if (hoursData.includes('|')) {
                                        const parsed = {};
                                        hoursData.split('|').forEach(entry => {
                                            const firstColonIndex = entry.indexOf(':');
                                            if (firstColonIndex !== -1) {
                                                const day = entry.substring(0, firstColonIndex).trim();
                                                const hours = entry.substring(firstColonIndex + 1).trim();
                                                if (day && hours) {
                                                    parsed[day.toLowerCase()] = hours;
                                                }
                                            }
                                        });
                                        hoursData = parsed;
                                    } else {
                                        return <li>Hours information not available</li>;
                                    }
                                }
                            }
                            
                            // Handle if it's an object
                            if (typeof hoursData === 'object' && hoursData !== null) {
                                return Object.entries(hoursData)
                                    .map(([day, hours]) => (
                                        <li>
                                            <span class="day">{day.charAt(0).toUpperCase() + day.slice(1)}</span>
                                            <span>{hours}</span>
                                        </li>
                                    ));
                            }
                            return <li>Hours information not available</li>;
                        })()}
                    </ul>
                </div>
            )}
        </div>
    </div>

    <!-- Illustration footer banner -->
    {illustrationUrl && (
        <div class="listing-footer-illustration">
            <img src={illustrationUrl} alt={listing.name} class="listing-footer-illustration__img" />
            <div class="listing-footer-illustration__fade"></div>
        </div>
    )}

) : (
    <!-- ════════ LIST PAGES (area, category, area+category) ════════ -->
    <section class={`list-hero${areaHeroUrl ? ' list-hero--has-image' : ''}`} style="background: linear-gradient(135deg, var(--parchment) 0%, var(--blush-light) 100%);">
        {areaHeroUrl && (
            <img
                src={areaHeroUrl}
                alt={`${areaTitle}, ${cityTitle}`}
                class="list-hero__img"
            />
        )}
        <div class="container list-hero__content">
            <Breadcrumbs crumbs={crumbs} />
            <h1 style="margin-top: var(--space-lg);">{pageTitle}</h1>
            <div class="divider"></div>
            <p class="text-secondary" style="font-size: 1.05rem;">
                {listings.length} {listings.length === 1 ? 'person' : 'people'} found
            </p>
        </div>
    </section>

    <section class="section">
        <div class="container">

            {type === 'area' && (
                <div class="browse-filters" style="margin-bottom: var(--space-2xl);">
                    {[...new Set(listings.map(l => normaliseCategory(l.category_slug)).filter(Boolean))].sort().map(cat => (
                        <a href={`/${citySlug}/${areaSlug}/${cat}`} class="filter-btn">
                            {getEmoji(cat)} {slugToTitle(cat)}
                        </a>
                    ))}
                </div>
            )}

            {type === 'city-category' && (
                <div class="neighbourhood-filter">
                    <p class="neighbourhood-filter__label">Filter by neighbourhood</p>
                    <div class="browse-filters browse-filters--compact">
                        {[...new Set(listings.map(l => l.area_slug).filter(Boolean))].sort().map(area => (
                            <a href={`/${citySlug}/${area}/${categorySlug}`} class="filter-btn filter-btn--sm" style="text-transform: capitalize;">
                                {area.replace(/-/g, ' ')}
                            </a>
                        ))}
                    </div>
                </div>
            )}

            {(type === 'city-category' || type === 'area-category') && getSubCategories(listings).length > 0 && (
                <SubCategoryFilter 
                    category={catTitle}
                    subCategories={getSubCategories(listings)}
                    selectedSubCategory={subCategorySlug}
                />
            )}

            <TieredListings listings={listings} />

            {listings.length === 0 && (
                <div style="text-align: center; padding: var(--space-4xl) 0;">
                    <p class="text-secondary" style="font-size: 1.1rem;">No listings found.</p>
                    <a href={`/${citySlug}`} class="btn btn--outline" style="margin-top: var(--space-lg);">
                        Browse all in {cityTitle}
                    </a>
                </div>
            )}
        </div>
    </section>

    <section class="section">
        <div class="container">
            <div class="cta-banner">
                <h2>Know someone doing great work here?</h2>
                <p>Meridian grows through community recommendations. If there's someone who deserves to be listed, let us know.</p>
                <a href="#" class="btn btn--accent">Suggest someone</a>
            </div>
        </div>
    </section>
)}

</BaseLayout>

<style>
    /* Contact Info Box */
    .contact-info-box {
        max-width: 1200px;
        margin: var(--space-2xl) auto 0;
        padding: 0 var(--space-lg);
    }

    .contact-info-container {
        background: var(--white);
        border: 1px solid var(--parchment);
        border-radius: var(--radius-sm);
        padding: var(--space-lg);
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: var(--space-lg);
    }

    .contact-item {
        display: flex;
        gap: var(--space-md);
    }

    .contact-icon {
        font-size: 1.5rem;
        min-width: 2rem;
        text-align: center;
    }

    .contact-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--silver);
        margin: 0;
    }

    .contact-value {
        font-size: 0.95rem;
        color: var(--taupe);
        margin: var(--space-xs) 0 0 0;
    }

    .contact-link {
        color: var(--powder-blush);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .contact-link:hover {
        color: var(--taupe);
    }

    .listing-section {
        margin-bottom: var(--space-2xl);
        padding-bottom: var(--space-2xl);
        border-bottom: 1px solid var(--parchment);
    }

    .listing-section h2 {
        margin-bottom: var(--space-lg);
        color: var(--grey-olive);
        font-size: 1.3rem;
    }

    /* Services List */
    .services-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: var(--space-md);
    }

    .service-item {
        padding: var(--space-md);
        background: linear-gradient(135deg, rgba(224, 175, 160, 0.08) 0%, rgba(224, 175, 160, 0.04) 100%);
        border-radius: var(--radius-sm);
        font-size: 0.95rem;
        color: var(--taupe);
        border-left: 3px solid var(--powder-blush);
    }

    /* Gallery Grid */
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
