---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TieredListings from '../../components/TieredListings.astro';
import ListingCard from '../../components/ListingCard.astro';
import StarRating from '../../components/StarRating.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import { supabase } from '../../lib/supabase';
import { slugToTitle, getEmoji, truncate } from '../../utils/helpers';

export async function getStaticPaths() {
    const { data: listings } = await supabase
        .from('listings')
        .select('*')
        .eq('status', 'Published');

    if (!listings) return [];

    // Collect all known category slugs for disambiguation
    const allCategories = new Set(listings.map(l => l.category_slug).filter(Boolean));

    const paths = [];
    const seen = new Set();

    listings.forEach(l => {
        // ── /bristol/cafes (city + category) ──
        if (l.category_slug) {
            const key = `cat:${l.city_slug}/${l.category_slug}`;
            if (!seen.has(key)) {
                seen.add(key);
                paths.push({
                    params: { city: l.city_slug, slug: [l.category_slug] },
                    props: {
                        type: 'city-category',
                        citySlug: l.city_slug,
                        categorySlug: l.category_slug,
                        allCategories: [...allCategories]
                    }
                });
            }
        }

        // ── /bristol/easton (city + area) ──
        if (l.area_slug && !allCategories.has(l.area_slug)) {
            const key = `area:${l.city_slug}/${l.area_slug}`;
            if (!seen.has(key)) {
                seen.add(key);
                paths.push({
                    params: { city: l.city_slug, slug: [l.area_slug] },
                    props: {
                        type: 'area',
                        citySlug: l.city_slug,
                        areaSlug: l.area_slug,
                        allCategories: [...allCategories]
                    }
                });
            }
        }

        // ── /bristol/easton/cafes (city + area + category) ──
        if (l.area_slug && l.category_slug) {
            const key = `areacat:${l.city_slug}/${l.area_slug}/${l.category_slug}`;
            if (!seen.has(key)) {
                seen.add(key);
                paths.push({
                    params: { city: l.city_slug, slug: [l.area_slug, l.category_slug] },
                    props: {
                        type: 'area-category',
                        citySlug: l.city_slug,
                        areaSlug: l.area_slug,
                        categorySlug: l.category_slug,
                        allCategories: [...allCategories]
                    }
                });
            }
        }

        // ── /bristol/easton/zamzam (individual listing) ──
        if (l.area_slug && l.business_slug) {
            paths.push({
                params: { city: l.city_slug, slug: [l.area_slug, l.business_slug] },
                props: {
                    type: 'listing',
                    citySlug: l.city_slug,
                    areaSlug: l.area_slug,
                    businessSlug: l.business_slug,
                    listing: l,
                    allCategories: [...allCategories]
                }
            });
        }
    });

    return paths;
}

// ── Determine page type and fetch data accordingly ──
const { type, citySlug, areaSlug, categorySlug, businessSlug, listing: directListing, allCategories } = Astro.props;
const { city, slug } = Astro.params;

let pageTitle = '';
let pageDescription = '';
let listings = [];
let listing = directListing || null;
let crumbs = [];

const cityTitle = slugToTitle(citySlug);
const areaTitle = slugToTitle(areaSlug);
const catTitle = slugToTitle(categorySlug);

if (type === 'city-category') {
    // ── /bristol/cafes ──
    pageTitle = `${catTitle} in ${cityTitle}`;
    pageDescription = `Browse ${catTitle.toLowerCase()} in ${cityTitle}. Ratings, reviews and contact details.`;
    crumbs = [
        { label: cityTitle, href: `/${citySlug}` },
        { label: catTitle }
    ];
    const { data } = await supabase
        .from('listings')
        .select('*')
        .eq('status', 'Published')
        .eq('city_slug', citySlug)
        .eq('category_slug', categorySlug)
        .order('is_featured', { ascending: false });
    listings = data || [];

} else if (type === 'area') {
    // ── /bristol/easton ──
    pageTitle = `Businesses in ${areaTitle}, ${cityTitle}`;
    pageDescription = `Discover local businesses in ${areaTitle}, ${cityTitle}.`;
    crumbs = [
        { label: cityTitle, href: `/${citySlug}` },
        { label: areaTitle }
    ];
    const { data } = await supabase
        .from('listings')
        .select('*')
        .eq('status', 'Published')
        .eq('city_slug', citySlug)
        .eq('area_slug', areaSlug)
        .order('is_featured', { ascending: false });
    listings = data || [];

} else if (type === 'area-category') {
    // ── /bristol/easton/cafes ──
    pageTitle = `${catTitle} in ${areaTitle}, ${cityTitle}`;
    pageDescription = `Find the best ${catTitle.toLowerCase()} in ${areaTitle}, ${cityTitle}.`;
    crumbs = [
        { label: cityTitle, href: `/${citySlug}` },
        { label: areaTitle, href: `/${citySlug}/${areaSlug}` },
        { label: catTitle }
    ];
    const { data } = await supabase
        .from('listings')
        .select('*')
        .eq('status', 'Published')
        .eq('city_slug', citySlug)
        .eq('area_slug', areaSlug)
        .eq('category_slug', categorySlug)
        .order('is_featured', { ascending: false });
    listings = data || [];

} else if (type === 'listing' && listing) {
    // ── /bristol/easton/zamzam ──
    pageTitle = listing.name;
    pageDescription = listing.description || `Find ${listing.name} in ${areaTitle}, ${cityTitle}.`;
    crumbs = [
        { label: cityTitle, href: `/${citySlug}` },
        { label: areaTitle, href: `/${citySlug}/${areaSlug}` },
        { label: listing.name }
    ];
}

// JSON-LD structured data for individual listings
const jsonLd = (type === 'listing' && listing) ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": listing.name,
    "description": listing.description,
    "address": {
        "@type": "PostalAddress",
        "addressLocality": cityTitle,
        "addressRegion": areaTitle,
        "addressCountry": "GB"
    },
    ...(listing.google_rating && {
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": listing.google_rating,
            "reviewCount": listing.google_review_count || 0
        }
    }),
    "image": listing.image_url,
    "telephone": listing.phone,
    "url": listing.website
}) : null;
---

<BaseLayout title={pageTitle} description={pageDescription}>

{jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

{type === 'listing' && listing ? (
    <!-- ════════ INDIVIDUAL LISTING PAGE ════════ -->
    <section class="listing-detail">
        <div class="container">
            <Breadcrumbs crumbs={crumbs} />

            <div class="listing-hero-grid">
                <div>
                    <!-- Tier + Category badges -->
                    <div style="display: flex; gap: 12px; align-items: center; margin-bottom: 16px; flex-wrap: wrap;">
                        {tier && tier.label && (
                            <span style={`display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 20px; font-size: .8rem; font-weight: 700; background: ${tier.bgColor}; color: ${tier.color}; border: 1px solid ${tier.borderColor};`}>
                                {tier.icon} {tier.label}
                            </span>
                        )}
                        {listing.is_featured && (
                            <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 20px; font-size: .8rem; font-weight: 700; background: #FFFBEB; color: #D97706; border: 1px solid #F59E0B;">
                                ⭐ Featured
                            </span>
                        )}
                        <span class="listing-tags"><span>{listing.category || 'Local Business'}</span></span>
                    </div>

                    <h1>{listing.name}</h1>
                    <StarRating rating={listing.google_rating} count={listing.google_review_count} />

                    <p style="font-size: 1.05rem; color: var(--muted); line-height: 1.8; margin: 20px 0;">
                        {listing.description || 'No description available.'}
                    </p>

                    <!-- Contact details -->
                    <div style="display: grid; gap: 12px;">
                        {listing.address && (
                            <div class="contact-row"><span>📍</span><span>{listing.address}</span></div>
                        )}
                        {listing.phone && (
                            <div class="contact-row"><span>📞</span><a href={`tel:${listing.phone}`}>{listing.phone}</a></div>
                        )}
                        {listing.email && (
                            <div class="contact-row"><span>✉️</span><a href={`mailto:${listing.email}`}>{listing.email}</a></div>
                        )}
                        {listing.website && (
                            <div class="contact-row"><span>🌐</span><a href={listing.website} target="_blank" rel="noopener">{listing.website}</a></div>
                        )}
                    </div>

                    <!-- Social Links -->
                    <SocialLinks listing={listing} />

                    <!-- Action buttons -->
                    <div class="listing-actions">
                        {listing.phone && <a href={`tel:${listing.phone}`} class="btn btn-primary">📞 Call Now</a>}
                        {listing.website && <a href={listing.website} target="_blank" class="btn btn-outline">🌐 Visit Website</a>}
                    </div>
                </div>

                <div class="listing-hero-image" style={`background-image: url('${listing.image_url || "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=800&q=80"}')`}></div>
            </div>
        </div>
    </section>
) : (

) : (
    <!-- ════════ LIST PAGE (area, category, area+category) ════════ -->
    <section class="listing-detail">
        <div class="container">
            <Breadcrumbs crumbs={crumbs} />

            <h1 class="section-title">{pageTitle}</h1>
            <p class="section-subtitle">{listings.length} {listings.length === 1 ? 'business' : 'businesses'} found</p>

            {type === 'area' && (
                <!-- Category filter links for area pages -->
                <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 32px;">
                    {[...new Set(listings.map(l => l.category_slug).filter(Boolean))].map(cat => (
                        <a href={`/${citySlug}/${areaSlug}/${cat}`} class="btn btn-outline" style="padding: 6px 16px; font-size: .85rem;">
                            {getEmoji(cat)} {slugToTitle(cat)}
                        </a>
                    ))}
                </div>
            )}

            {type === 'city-category' && (
                <!-- Area filter links for city-category pages -->
                <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 32px;">
                    {[...new Set(listings.map(l => l.area_slug).filter(Boolean))].map(area => (
                        <a href={`/${citySlug}/${area}/${categorySlug}`} class="btn btn-outline" style="padding: 6px 16px; font-size: .85rem;">
                            📍 {slugToTitle(area)}
                        </a>
                    ))}
                </div>
            )}

            <div class="listings-grid">
                {listings.map(item => (
                    <ListingCard listing={item} />
                ))}
            </div>

            {listings.length === 0 && (
                <p style="text-align: center; color: var(--muted); padding: 60px 0;">
                    No listings found. <a href={`/${citySlug}`} style="color: var(--primary);">Browse all in {cityTitle}</a>
                </p>
            )}
        </div>
    </section>
)}

</BaseLayout>
