---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import TieredListings from '../components/TieredListings.astro';
import { supabase } from '../lib/supabase.js';
import { slugToTitle, getEmoji, sortByTier, groupByTier } from '../utils/helpers.js';

const { data: allListings } = await supabase
    .from('listings')
    .select('*')
    .eq('status', 'Published');

const cityCounts = {};
allListings?.forEach(l => { if (l.city_slug) cityCounts[l.city_slug] = (cityCounts[l.city_slug] || 0) + 1; });

const categoryCounts = {};
allListings?.forEach(l => { if (l.category_slug) categoryCounts[l.category_slug] = (categoryCounts[l.category_slug] || 0) + 1; });

const totalListings = allListings?.length || 0;
const firstCity = Object.keys(cityCounts)[0];
const allGroups = groupByTier(allListings || []);
const standardListings = (allGroups.standard || []).slice(0, 18);
---

<BaseLayout>

<!-- Hero -->
<section class="hero">
    <div class="hero__content">
        <div class="hero__text">
            <h1>Discover the <em>real people</em> behind your community</h1>
            <p>locale is a community of local insights helping you find the hidden gems — the people doing great work, right where you live.</p>
            <div class="hero__actions">
                <a href={firstCity ? `/${firstCity}` : '#'} class="btn btn--primary">Explore the Directory</a>
                <a href="#categories" class="btn btn--outline">See Categories</a>
            </div>
            <div class="search-bar">
                <input id="hero-search-input" type="text" placeholder="Search businesses, categories, areas...">
                <button id="hero-search-btn">Search</button>
            </div>
            <script>
                const input = document.getElementById('hero-search-input') as HTMLInputElement;
                const btn = document.getElementById('hero-search-btn') as HTMLButtonElement;
                function goSearch() {
                    const q = input.value.trim();
                    if (q) window.location.href = '/search?q=' + encodeURIComponent(q);
                }
                btn.addEventListener('click', goSearch);
                input.addEventListener('keydown', e => { if (e.key === 'Enter') goSearch(); });
            </script>
        </div>
        <div class="hero__mosaic">
            <img src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=600&q=80" alt="Local maker at work" class="hero__mosaic-img">
            <img src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?auto=format&fit=crop&w=400&q=80" alt="Craftsperson in workshop" class="hero__mosaic-img">
            <img src="https://images.unsplash.com/photo-1607344645866-009c320b63e0?auto=format&fit=crop&w=400&q=80" alt="Fresh local produce" class="hero__mosaic-img">
        </div>
    </div>
</section>

<!-- Featured Listings -->
<section class="section" id="highlights">
    <div class="container">
        <div class="section-header flex-between">
            <div>
                <h2>People doing great work</h2>
                <div class="divider"></div>
                <p>Hand-picked from your community — these are the people your neighbours trust and recommend.</p>
            </div>
            {firstCity && <a href={`/${firstCity}`} class="btn btn--ghost">View all →</a>}
        </div>

        <TieredListings listings={allListings} excludeTiers={['standard']} />
    </div>
</section>

<!-- Categories -->
<section class="section" id="categories" style="background: var(--white);">
    <div class="container">
        <div class="section-header section-header--center">
            <h2>Browse by category</h2>
            <div class="divider divider--center"></div>
            <p>Find the right person for what you need — every listing is here because they deserve to be.</p>
        </div>
        <div class="category-grid">
            {Object.entries(categoryCounts).map(([cat, count]) => (
                <a href={firstCity ? `/${firstCity}/${cat}` : '#'} class="category-card">
                    <div class="category-card__icon">{getEmoji(cat)}</div>
                    <div class="category-card__text">
                        <h4>{slugToTitle(cat)}</h4>
                        <p>{count} {count === 1 ? 'person' : 'people'} listed</p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<!-- Standard listings (capped at 18) -->
{standardListings.length > 0 && (
<section class="section" id="community">
    <div class="container">
        <div class="section-header flex-between">
            <div>
                <h2>More from the community</h2>
                <div class="divider"></div>
                <p>More independent people doing great work near you.</p>
            </div>
            {firstCity && <a href={`/${firstCity}`} class="btn btn--ghost">View all →</a>}
        </div>
        <div class="browse-grid">
            {standardListings.map(item => (
                <ListingCard listing={item} />
            ))}
        </div>
    </div>
</section>
)}

<!-- Browse by City -->
<section class="section" style="background: var(--white);">
    <div class="container">
        <div class="section-header section-header--center">
            <h2>Browse by city</h2>
            <div class="divider divider--center"></div>
            <p>Select a city to discover the people doing great work near you.</p>
        </div>
        <div class="areas-grid" style="max-width: 800px; margin: 0 auto;">
            {Object.entries(cityCounts).map(([city, count]) => (
                <a href={`/${city}`} class="area-card">
                    <div>
                        <h3 style="text-transform: capitalize;">📍 {city.replace(/-/g, ' ')}</h3>
                        <p>{count} {count === 1 ? 'person' : 'people'} listed</p>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section">
    <div class="container">
        <div class="cta-banner">
            <h2>Doing great work in your community?</h2>
            <p>Meridian is for independent people who care about their craft. If that's you, we'd love to include you.</p>
            <a href="#" class="btn btn--accent">Apply to be listed</a>
        </div>
    </div>
</section>

</BaseLayout>
