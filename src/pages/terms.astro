        </section>

        <section>
            <h2>9. Contact Information</h2>
            <p>If you have any questions about these Terms of Service, please contact us at:</p>
            <ul>
                <li>By email: [email to be filled in]</li>
                <li>By visiting: [contact page to be filled in]</li>
            </ul>
        </section>
    </div>
</BaseLayout>

<style>
    .legal-page {
        max-width: 800px;
        margin: 3rem auto;
        padding: 2rem;
    }

    .legal-page h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .last-updated {
        color: #666;
        font-size: 0.95rem;
        margin-bottom: 2rem;
    }

    .legal-page section {
        margin: 2rem 0;
    }

    .legal-page h2 {
        font-size: 1.5rem;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
    }

    .legal-page p {
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .legal-page ul {
        margin-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .legal-page li {
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }
</style>
