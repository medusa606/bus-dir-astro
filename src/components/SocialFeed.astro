---
interface Props {
    feed?: Array<{
        platform: 'facebook' | 'instagram' | 'twitter' | 'tiktok' | 'youtube' | 'linkedin';
        text: string;
        date: string;
        link?: string;
    }>;
    maxItems?: number;
}

const { feed = [], maxItems = 3 } = Astro.props;

// Show only the first maxItems
const displayedFeed = feed.slice(0, maxItems);

const platformColors = {
    instagram: '#E1306C',
    facebook: '#1877F2',
    twitter: '#000000',
    tiktok: '#000000',
    youtube: '#FF0000',
    linkedin: '#0A66C2'
};
---

{displayedFeed.length > 0 && (
    <div class="social-feed">
        <p class="feed-label">Latest Updates</p>
        <div class="feed-items">
            {displayedFeed.map((post) => (
                <div class="feed-item" style={`--platform-color: ${platformColors[post.platform]}`}>
                    <span class="feed-platform">{post.platform}</span>
                    <p class="feed-text">{post.text}</p>
                    <span class="feed-date">{post.date}</span>
                    {post.link && (
                        <a href={post.link} target="_blank" rel="noopener noreferrer" class="feed-link">
                            View post →
                        </a>
                    )}
                </div>
            ))}
        </div>
    </div>
)}

<style>
    .social-feed {
        margin-top: var(--space-lg);
        padding-top: var(--space-lg);
        border-top: 1px solid var(--parchment);
    }

    .feed-label {
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: var(--grey-olive);
        margin-bottom: var(--space-md);
    }

    .feed-items {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .feed-item {
        padding: var(--space-md);
        background: linear-gradient(
            135deg,
            rgba(224, 175, 160, 0.08) 0%,
            rgba(224, 175, 160, 0.04) 100%
        );
        border-left: 3px solid var(--platform-color);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        font-size: 0.85rem;
        transition: var(--transition);
    }

    .feed-item:hover {
        background: rgba(224, 175, 160, 0.12);
        transform: translateX(4px);
    }

    .feed-platform {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--platform-color);
        margin-bottom: var(--space-xs);
        letter-spacing: 0.05em;
    }

    .feed-text {
        color: var(--taupe);
        margin-bottom: var(--space-xs);
        line-height: 1.5;
        font-size: 0.9rem;
    }

    .feed-date {
        display: block;
        font-size: 0.75rem;
        color: var(--silver);
        font-weight: 500;
    }

    .feed-link {
        display: inline-block;
        margin-top: var(--space-xs);
        font-size: 0.75rem;
        color: var(--powder-blush);
        font-weight: 600;
        transition: var(--transition);
        text-decoration: none;
    }

    .feed-link:hover {
        color: var(--taupe);
        transform: translateX(2px);
    }
</style>
