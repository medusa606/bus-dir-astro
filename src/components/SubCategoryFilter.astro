---
import type { AstroComponentFactory } from 'astro';

interface Props {
  category: string;
  subCategories: { name: string; count: number; slug: string }[];
  selectedSubCategory?: string;
  onSelect?: (subCategory: string) => void;
}

const { category, subCategories, selectedSubCategory } = Astro.props;
---

<div class="sub-category-filter">
  <div class="filter-header">
    <h3>Filter by {category}</h3>
    {selectedSubCategory && (
      <a href="#" class="clear-filter" onclick="window.location.hash = ''">
        Clear filter
      </a>
    )}
  </div>

  <div class="filter-pills">
    {subCategories && subCategories.length > 0 ? (
      subCategories.map((subCat) => (
        <a
          href={`?subCategory=${encodeURIComponent(subCat.slug)}`}
          class={`filter-pill ${selectedSubCategory === subCat.slug ? 'active' : ''}`}
          title={`${subCat.count} ${subCat.name} listings`}
        >
          <span class="name">{subCat.name}</span>
          <span class="count">{subCat.count}</span>
        </a>
      ))
    ) : (
      <p class="no-subcategories">No sub-categories available</p>
    )}
  </div>
</div>

<style>
  .sub-category-filter {
    margin: 1.5rem 0;
    padding: 1rem;
    background: linear-gradient(135deg, #f5f5f5 0%, #f9f9f9 100%);
    border-radius: 8px;
    border-left: 4px solid var(--primary, #0066cc);
  }

  .filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .filter-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #333;
  }

  .clear-filter {
    font-size: 0.875rem;
    color: #0066cc;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .clear-filter:hover {
    background: rgba(0, 102, 204, 0.1);
    text-decoration: underline;
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: white;
    border: 1px solid #ddd;
    border-radius: 20px;
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    color: #333;
  }

  .filter-pill:hover {
    border-color: #0066cc;
    background: rgba(0, 102, 204, 0.05);
  }

  .filter-pill.active {
    background: #0066cc;
    color: white;
    border-color: #0066cc;
    font-weight: 600;
  }

  .filter-pill .count {
    font-size: 0.75rem;
    opacity: 0.7;
    font-weight: 500;
  }

  .filter-pill.active .count {
    opacity: 0.9;
  }

  .no-subcategories {
    color: #999;
    font-size: 0.875rem;
    margin: 0;
    padding: 0.5rem 0;
  }

  @media (max-width: 640px) {
    .sub-category-filter {
      margin: 1rem 0;
      padding: 0.75rem;
    }

    .filter-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .filter-pills {
      gap: 0.375rem;
    }

    .filter-pill {
      padding: 0.4rem 0.8rem;
      font-size: 0.8rem;
    }
  }
</style>
