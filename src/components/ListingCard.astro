---
import StarRating from './StarRating.astro';
import SocialIcon from './SocialIcon.astro';
import { getEmoji, truncate, RANKING_TIERS, normalizeSocialUrl } from '../utils/helpers.js';
import { getTagBasedImage, getImageByCategory } from '../utils/categoryImages.js';

const { listing } = Astro.props;
const href = `/${listing.city_slug}/${listing.area_slug}/${listing.business_slug}`;
const imgUrl = listing.image_url
    || listing.image_key
    || (listing.image_category && getImageByCategory(listing.image_category, listing.business_slug))
    || getTagBasedImage(listing.tags, listing.category_slug, listing.business_slug)
    || '/placeholders/default.svg';
const tier = RANKING_TIERS[listing.ranking_tier] || RANKING_TIERS.standard;

const socials = [
    { key: 'social_facebook',  platform: 'facebook',  label: 'Facebook' },
    { key: 'social_instagram', platform: 'instagram', label: 'Instagram' },
    { key: 'social_twitter',   platform: 'twitter',   label: 'X' },
    { key: 'social_tiktok',    platform: 'tiktok',    label: 'TikTok' },
    { key: 'social_linkedin',  platform: 'linkedin',  label: 'LinkedIn' },
    { key: 'social_youtube',   platform: 'youtube',   label: 'YouTube' },
].filter(s => listing[s.key]);

const cardClasses = [
    'card',
    listing.ranking_tier === 'recommended' && 'card--recommended',
    listing.ranking_tier === 'editors_choice' && 'card--editors'
].filter(Boolean).join(' ');
---
<div class={cardClasses} data-sub-category={listing.sub_category ? listing.sub_category.toLowerCase() : ''}>
    <div class="card__media">
        <a href={href}>
            <img src={imgUrl} alt={listing.name} class="card__image">
        </a>
        {listing.ranking_tier === 'recommended' && (
            <div class="card-marker card-marker--recommended" aria-hidden="true">
                <svg viewBox="0 0 48 48" role="presentation">
                    <path d="M24 4.5l5.7 11.6 12.8 1.9-9.3 9.1 2.2 12.8L24 33.8 12.6 39.9l2.2-12.8-9.3-9.1 12.8-1.9z" fill="#ffd766" stroke="#d97706" stroke-width="2"></path>
                    <path d="M24 9.5l4 8.1 9 1.3-6.5 6.3 1.5 9-8-4.2-8 4.2 1.5-9-6.5-6.3 9-1.3z" fill="#fff8dc" opacity="0.9"></path>
                </svg>
            </div>
        )}
        {listing.ranking_tier === 'editors_choice' && (
            <div class="card-marker card-marker--editors" aria-hidden="true">
                <img src="/awards/rosette-vector-sml.png" alt="" class="card-marker__image">
            </div>
        )}
    </div>
    <a href={href}>
        <div class="card__body">
            <div class="card__meta">
                <span class="tag tag--category">{listing.category || 'Local Business'}</span>
                {tier.label && (
                    <span class={`tag tag--tier-${listing.ranking_tier === 'editors_choice' ? 'editors' : listing.ranking_tier === 'recommended' ? 'recommended' : 'google'}`}>
                        {listing.ranking_tier === 'editors_choice' && <span style="color:#7c3aed;">★</span>}
                        {listing.ranking_tier !== 'editors_choice' && tier.icon} {tier.label}
                    </span>
                )}
                <span class="tag tag--location" style="text-transform: capitalize;">
                    📍 {listing.area_slug?.replace(/-/g, ' ')}
                </span>
            </div>
            <h3 class="card__title">{listing.name}</h3>
            {listing.google_rating && (
                <p class="card__subtitle">
                    ★ {listing.google_rating} ({listing.google_review_count || 0} reviews)
                </p>
            )}
            {listing.description && <p class="card__excerpt">{truncate(listing.description)}</p>}
            {socials.length > 0 && (
                <div style="margin: var(--space-lg) var(--space-lg) 0 0;">
                    <div class="social-links social-links--sm">
                        {socials.map(s => (
                            <a href={normalizeSocialUrl(s.platform, listing[s.key])} target="_blank" rel="noopener noreferrer" class="social-link" title={s.label}>
                                <SocialIcon platform={s.platform} size={14} />
                            </a>
                        ))}
                    </div>
                </div>
            )}
        </div>
    </a>
    </div>
    {listing.ranking_tier === 'editors_choice' && listing.editors_notes && (
        <aside class="editor-note">
            <p class="editor-note__eyebrow">Locale says...</p>
            <p>{listing.editors_notes}</p>
        </aside>
    )}
</div>
