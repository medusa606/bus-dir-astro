---
import ListingCard from './ListingCard.astro';
import { groupByTier, RANKING_TIERS } from '../utils/helpers.js';

const { listings } = Astro.props;
const groups = groupByTier(listings || []);
const tierOrder = ['editors_choice', 'recommended', 'google_ranked', 'standard'];

const tierCssMap = {
    editors_choice: 'editors',
    recommended: 'recommended',
    google_ranked: 'google',
    standard: 'standard'
};
---

{tierOrder.map(tierKey => {
    const items = groups[tierKey];
    if (!items || items.length === 0) return null;
    const tier = RANKING_TIERS[tierKey];
    const cssKey = tierCssMap[tierKey];

    return (
        <div style="margin-bottom: var(--space-2xl);">
            {tier.label ? (
                <div class={`tier-header tier-header--${cssKey}`}>
                    <span class="tier-header__icon">{tier.icon}</span>
                    <div class="tier-header__text">
                        <h3>{tier.label}</h3>
                        <p>{tier.description}</p>
                    </div>
                    <span class="tier-header__count">
                        {items.length} {items.length === 1 ? 'listing' : 'listings'}
                    </span>
                </div>
            ) : (
                <div class="tier-header tier-header--standard">
                    <div class="tier-header__text">
                        <h3>All Listings</h3>
                    </div>
                    <span class="tier-header__count">{items.length} listings</span>
                </div>
            )}

            <div class="browse-grid">
                {items.map(item => (
                    <ListingCard listing={item} />
                ))}
            </div>
        </div>
    );
})}
