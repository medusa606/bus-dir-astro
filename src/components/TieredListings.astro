---
import ListingCard from './ListingCard.astro';
import { groupByTier, RANKING_TIERS } from '../utils/helpers.js';

const { listings } = Astro.props;
const groups = groupByTier(listings || []);

const tierOrder = ['editors_choice', 'recommended', 'google_ranked', 'standard'];
---

{tierOrder.map(tierKey => {
    const items = groups[tierKey];
    if (!items || items.length === 0) return null;
    const tier = RANKING_TIERS[tierKey];

    return (
        <div style="margin-bottom: 48px;">
            {tier.label && (
                <div style={`
                    display: flex; align-items: center; gap: 12px;
                    margin-bottom: 20px; padding: 12px 20px;
                    background: ${tier.bgColor}; border-radius: 8px;
                    border-left: 4px solid ${tier.color};
                `}>
                    <span style="font-size: 1.4rem;">{tier.icon}</span>
                    <div>
                        <h3 style={`font-size: 1.1rem; font-weight: 700; color: ${tier.color}; margin: 0;`}>
                            {tier.label}
                        </h3>
                        <p style="font-size: .82rem; color: var(--muted); margin: 0;">
                            {tier.description}
                        </p>
                    </div>
                    <span style="margin-left: auto; font-size: .85rem; color: var(--muted);">
                        {items.length} {items.length === 1 ? 'business' : 'businesses'}
                    </span>
                </div>
            )}

            {!tier.label && (
                <div style="margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid #E5E7EB;">
                    <h3 style="font-size: 1rem; font-weight: 600; color: var(--muted);">
                        All Listings ({items.length})
                    </h3>
                </div>
            )}

            <div class="listings-grid">
                {items.map(item => (
                    <ListingCard listing={item} />
                ))}
            </div>
        </div>
    );
})}
