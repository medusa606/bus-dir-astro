---
const { listing } = Astro.props;

const socials = [
    { key: 'social_facebook',  label: 'Facebook',  icon: 'f',  color: '#1877F2' },
    { key: 'social_instagram', label: 'Instagram', icon: '📷', color: '#E4405F' },
    { key: 'social_twitter',   label: 'X/Twitter', icon: '𝕏',  color: '#000000' },
    { key: 'social_tiktok',    label: 'TikTok',    icon: '♪',  color: '#000000' },
    { key: 'social_linkedin',  label: 'LinkedIn',  icon: 'in', color: '#0A66C2' },
    { key: 'social_youtube',   label: 'YouTube',   icon: '▶',  color: '#FF0000' },
].filter(s => listing[s.key]);
---

{socials.length > 0 && (
    <div class="social-links">
        {socials.map(s => (
            <a
                href={listing[s.key]}
                target="_blank"
                rel="noopener noreferrer"
                title={s.label}
                class="social-link"
                style={`--social-color: ${s.color};`}
            >
                <span class="social-icon">{s.icon}</span>
            </a>
        ))}
    </div>
)}
