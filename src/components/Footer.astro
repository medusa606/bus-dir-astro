---
import { supabase } from '../lib/supabase';

// Fetch cities for footer links
const { data: cityData } = await supabase
    .from('listings')
    .select('city_slug')
    .eq('status', 'Published');

const cities = [...new Set(cityData?.map(l => l.city_slug).filter(Boolean))];
---
<footer>
    <div class="container">
        <div class="footer-grid">
            <div class="footer-brand">
                <div class="logo">📍 Local<span>Pulse</span></div>
                <p>Connecting communities with the businesses they love. Your trusted local business directory.</p>
            </div>
            <div>
                <h4>Cities</h4>
                <ul>
                    {cities.slice(0, 6).map(city => (
                        <li><a href={`/${city}`} style="text-transform: capitalize;">{city.replace(/-/g, ' ')}</a></li>
                    ))}
                </ul>
            </div>
            <div>
                <h4>For Business</h4>
                <ul>
                    <li><a href="#">Add Listing</a></li>
                    <li><a href="/#pricing">Pricing Plans</a></li>
                    <li><a href="#">Advertising</a></li>
                </ul>
            </div>
            <div>
                <h4>Company</h4>
                <ul>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; {new Date().getFullYear()} LocalPulse. All rights reserved.</p>
        </div>
    </div>
</footer>
