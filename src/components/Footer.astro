---
import { supabase } from '../lib/supabase.js';

const { data: cityData } = await supabase
    .from('listings')
    .select('city_slug')
    .eq('status', 'Published');

const cities = [...new Set(cityData?.map(l => l.city_slug).filter(Boolean))];

const { data: catData } = await supabase
    .from('listings')
    .select('category_slug')
    .eq('status', 'Published');

const categories = [...new Set(catData?.map(l => l.category_slug).filter(Boolean))].slice(0, 5);

import { slugToTitle } from '../utils/helpers.js';
---
<footer class="footer">
    <div class="footer__grid">
        <div class="footer__brand">
            <div class="footer__logo">Meridian<span>.</span></div>
            <p>A curated community directory — surfacing the real people behind your local economy. No ads, no algorithms, just trust.</p>
        </div>
        <div class="footer__column">
            <h4>Cities</h4>
            <ul>
                {cities.slice(0, 6).map(city => (
                    <li><a href={`/${city}`} style="text-transform: capitalize;">{city.replace(/-/g, ' ')}</a></li>
                ))}
            </ul>
        </div>
        <div class="footer__column">
            <h4>Categories</h4>
            <ul>
                {categories.map(cat => (
                    <li><a href={cities[0] ? `/${cities[0]}/${cat}` : '#'}>{slugToTitle(cat)}</a></li>
                ))}
            </ul>
        </div>
        <div class="footer__column">
            <h4>Get Involved</h4>
            <ul>
                <li><a href="#">Apply to be listed</a></li>
                <li><a href="#">Suggest someone</a></li>
                <li><a href="#">Contact us</a></li>
                <li><a href="/privacy">Privacy</a></li>
            </ul>
        </div>
    </div>
    <div class="footer__bottom">
        <span>&copy; {new Date().getFullYear()} Meridian. Made with care.</span>
        <div class="footer__bottom-links">
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
            <a href="/accessibility">Accessibility</a>
        </div>
    </div>
</footer>
