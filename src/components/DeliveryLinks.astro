---
const { listing, small = false } = Astro.props;

// Delivery platform fields with actual logo paths
const deliveryPlatforms = [
    { 
        key: 'delivery_deliveroo', 
        platform: 'deliveroo', 
        label: 'Order on Deliveroo',
        logo: '/delivery/Deliveroo/Deliveroo_id1cblHFGi_4.png'
    },
    { 
        key: 'delivery_ubereats', 
        platform: 'ubereats', 
        label: 'Order on Uber Eats',
        logo: '/delivery/Uber_Eats/Uber_Eats_Symbol_7.png'
    },
    { 
        key: 'delivery_justeat', 
        platform: 'justeat', 
        label: 'Order on Just Eat',
        logo: '/delivery/JustEat/Just-Eat_idN2HSXxTx_0.png'
    },
    { 
        key: 'delivery_foodhub', 
        platform: 'foodhub', 
        label: 'Order on Foodhub',
        logo: '/delivery/FoodHub/Foodhub_idoedAE3Hj_0.png'
    },
    { 
        key: 'delivery_beelivery', 
        platform: 'beelivery', 
        label: 'Order on Beelivery',
        logo: '/delivery/Beelivery/Beelivery_ideEbmTtRP_2.png'
    },
    { 
        key: 'delivery_opentable', 
        platform: 'opentable', 
        label: 'Reserve on OpenTable',
        logo: '/bookings/openTable/opentable-logo-ZGYRVF2L.svg'
    },
].filter(d => listing[d.key]);
---

{deliveryPlatforms.length > 0 && (
    <div class={`delivery-links ${small ? 'delivery-links--sm' : ''}`}>
        {deliveryPlatforms.map(d => (
            <a
                href={listing[d.key]}
                target="_blank"
                rel="noopener noreferrer"
                class={`delivery-badge delivery-badge--${d.platform}`}
                title={d.label}
                data-platform={d.platform}
            >
                <span class="delivery-badge__icon">
                    <img src={d.logo} alt={d.label} />
                </span>
                <span class="delivery-badge__text">{d.label}</span>
            </a>
        ))}
    </div>
)}

<style>
    .delivery-links {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
        padding: var(--space-md) 0;
        border-top: 1px solid var(--parchment);
        margin-top: var(--space-md);
    }

    .delivery-links--sm {
        gap: var(--space-sm);
        margin-top: var(--space-sm);
        padding: var(--space-sm) 0;
        flex-direction: row;
        flex-wrap: wrap;
    }

    .delivery-badge {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        padding: var(--space-md) var(--space-lg);
        text-decoration: none;
        border-radius: var(--radius-md);
        transition: var(--transition);
        font-weight: 600;
        font-size: 0.95rem;
        border: 1px solid #ddd;
        cursor: pointer;
        background: white;
        color: var(--taupe);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .delivery-badge:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
        transform: translateY(-2px);
        border-color: var(--powder-blush);
    }

    .delivery-badge--deliveroo:hover {
        background: #f0fdf9;
    }

    .delivery-badge--ubereats:hover {
        background: #f5f5f5;
    }

    .delivery-badge--justeat:hover {
        background: #fff8f0;
    }

    .delivery-badge--foodhub:hover {
        background: #fff0f0;
    }

    .delivery-badge--beelivery:hover {
        background: #fffbf0;
    }

    .delivery-badge--opentable:hover {
        background: #fef0f0;
    }

    .delivery-badge__icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 35px;
        height: 35px;
        flex-shrink: 0;
        background: #f8f8f8;
        border-radius: var(--radius-sm);
    }

    .delivery-badge__icon img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        padding: 2px;
    }

    .delivery-badge__placeholder {
        font-size: 1.3rem;
    }

    .delivery-badge__text {
        white-space: nowrap;
        font-weight: 600;
    }

    /* Small variant */
    .delivery-links--sm .delivery-badge {
        padding: var(--space-sm) var(--space-md);
        font-size: 0.85rem;
    }

    .delivery-links--sm .delivery-badge__icon {
        width: 32px;
        height: 32px;
    }

    /* Mobile responsive */
    @media (max-width: 640px) {
        .delivery-links {
            flex-direction: column;
        }

        .delivery-badge {
            padding: var(--space-md) var(--space-lg);
        }
    }
</style>
