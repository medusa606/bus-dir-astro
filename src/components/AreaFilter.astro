---
interface Props {
  listings: any[];
  citySlug: string;
  categorySlug: string;
}

const { listings, citySlug, categorySlug } = Astro.props;

// Count listings per area
const areaCounts: Record<string, number> = {};
listings?.forEach(l => {
  if (l.area_slug) {
    areaCounts[l.area_slug] = (areaCounts[l.area_slug] || 0) + 1;
  }
});

// Sort areas by listing count (descending), then alphabetically
const sortedAreas = Object.entries(areaCounts)
  .sort((a, b) => {
    if (b[1] !== a[1]) return b[1] - a[1]; // Sort by count descending
    return a[0].localeCompare(b[0]); // Then alphabetically
  });

// Split into top 6 and rest
const topAreas = sortedAreas.slice(0, 6);
const moreAreas = sortedAreas.slice(6);
---

<div class="neighbourhood-filter">
  <p class="neighbourhood-filter__label">Filter by neighbourhood</p>
  <div class="browse-filters browse-filters--compact" id="area-filter-container">
    <!-- Top 6 areas (always visible) -->
    {topAreas.map(([area, count]) => (
      <a 
        href={`/${citySlug}/${area}/${categorySlug}`} 
        class="filter-btn filter-btn--sm area-filter-btn" 
        style="text-transform: capitalize;"
        data-area-count={count}
      >
        {area.replace(/-/g, ' ')}
      </a>
    ))}
    
    <!-- More areas (hidden by default) -->
    {moreAreas.length > 0 && (
      <>
        <div class="area-filter-more" id="area-filter-more" style="display: none;">
          {moreAreas.map(([area, count]) => (
            <a 
              href={`/${citySlug}/${area}/${categorySlug}`} 
              class="filter-btn filter-btn--sm area-filter-btn" 
              style="text-transform: capitalize;"
              data-area-count={count}
            >
              {area.replace(/-/g, ' ')}
            </a>
          ))}
        </div>
        
        <!-- More button -->
        <button 
          id="area-filter-more-btn" 
          class="filter-btn filter-btn--sm filter-btn--more"
          type="button"
          aria-expanded="false"
        >
          more...
        </button>
      </>
    )}
  </div>
</div>

<script>
  // Handle more/less toggle
  const moreBtn = document.getElementById('area-filter-more-btn');
  const moreContainer = document.getElementById('area-filter-more');
  
  if (moreBtn && moreContainer) {
    moreBtn.addEventListener('click', () => {
      const isExpanded = moreBtn.getAttribute('aria-expanded') === 'true';
      
      if (isExpanded) {
        // Collapse
        moreContainer.style.display = 'none';
        moreBtn.textContent = 'more...';
        moreBtn.setAttribute('aria-expanded', 'false');
      } else {
        // Expand
        moreContainer.style.display = 'contents';
        moreBtn.textContent = 'less...';
        moreBtn.setAttribute('aria-expanded', 'true');
      }
    });
  }
</script>

<style>
  .area-filter-more {
    display: contents;
  }

  .filter-btn--more {
    color: var(--silver);
    cursor: pointer;
    border-style: dashed;
    opacity: 0.8;
    transition: all 0.2s ease;
  }

  .filter-btn--more:hover {
    opacity: 1;
    border-color: var(--taupe);
    color: var(--taupe);
  }
</style>
